.content{
    width: 100%;
    height: 100vh;
    background-color: #efefef;
}

.content-hotel{
    width: 100%;
    height: 600rpx;
}
.hotel-swiper{
    width: 100%;
    height: 400rpx;
}
.hotel-swiper image{
    width: 100%;
    height: 400rpx;
}
.hotel-info{
    width: 100%;
    height: 200rpx;
    padding-left: 20rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    color: #9195a3;
}
.info-title{
    font-size: 36rpx;
    font-weight: bold;
}
.info-scroe{
    font-size: 26rpx;
}
.info-price{
    font-size: 28rpx;
    color: #ff0000;
}
/* 选择住宿日期部分 */
.chooseDate{
    width: 100%;
    height: 150rpx;
    margin-top:30rpx;
    padding: 20rpx;
    box-sizing: border-box;
}
.chooseDate .chooseDate-title text{
    font-size: 26rpx;
    color:gray;
}
.chooseDate-picker{
    width: 100%;
    height: 60rpx;
    display: flex;
    align-items: center;
}
.picker-start{
    margin-right: 150rpx;
}
.orderInfo{
    width: 100%;
    height: 80rpx;
    padding: 20rpx;
    box-sizing: border-box;
    display: flex;
    font-size: 28rpx;
    color: gray;
}