page{
    background-color: #efefef;
}
.content{
    width: 100%;
    background-color: #efefef;
}

.hotel-order{
    width: 100%;
    display: flex;
    flex-direction: column;
}
.order-item{
    width: 700rpx;
    height: 200rpx;
    margin: 15rpx 25rpx;
    padding: 20rpx;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    background-color: #fff;
    border-radius: 20rpx;
}
.order-item .itemDetail{
    margin-left: 20rpx;
    display: flex;
}
.order-item .itemDetail .detail-info{
    height: 150rpx;
    width: 400rpx;
    display: flex;
    justify-content: space-around;
    flex-direction: column;
}
.order-item .itemDetail image{
    width: 150rpx;
    height: 150rpx;
    margin-right: 30rpx;
    background-color: skyblue;
}
.order-item .itemDetail .detail-info .title{
    font-size: 30rpx;
    color: #9195a3;
}
.order-item .itemDetail .detail-info .days{
    font-size: 26rpx;
    color: #9195a3;
}
.order-item .itemDetail .detail-info .other{
    width: 400rpx;
    display: flex;
    justify-content: space-between;
    font-size: 26rpx;
    color: #9195a3;
}
.order-item .itemDetail .detail-info .other .del-btn{
    font-size: 24rpx;
    color: red;
}
/* 没有订单 */
.info-tip{
    width: 100%;
    height: 300rpx;
    text-align: center;
    line-height: 300rpx;
}
.info-tip text{
    font-size: 30rpx;
    color: #9195a3;
}
/* 底部固定功能区 */
.order-ability{
    width: 100%;
    height: 120rpx;
    position: fixed;
    left: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: space-around;
    background-color: #9195a3;
    color: white;
    padding-bottom: env(safe-area-inset-bottom);
    padding-bottom:constant(safe-area-inset-bottom);
}