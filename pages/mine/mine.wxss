/* pages/mine/mine.wxss */
page{
    background-color: #efefef;
}
.mine-header{
    width: 100%;
    height: 450rpx;
    padding: 50rpx;
    box-sizing: border-box;
    display: flex;
}
.header-avatar{
    width: 250rpx;
    height: 250rpx;
}
.header-avatar .avatar{
    width: 250rpx;
    height: 250rpx;
    border-radius: 50%;
}
.header-userInfo{
    padding: 50rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
}
.userInfo-name{
    margin-bottom: 30rpx;
    font-size: 40rpx;
    color: #000;
    font-weight: bold;
}
.userInfo-login{
    color:#9195a3;
}
/* 主体表单功能区 */
.mine-content{
    width: 750rpx;
    padding: 0 30rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
}
.content-item{
    width: 100%;
    height: 100rpx;
    padding: 0 20rpx;
    box-sizing: border-box;
    position: relative;
    display: flex;
    align-items: center;
    background-color: #fff;
    border-bottom: 1px solid #9195a3;
}
.mine-content :nth-child(5){
    border-bottom: none;
}
.content-item .item-bg{
    width: 60rpx;
    height: 60rpx;
    margin-right: 30rpx;
}
.content-item .item-title{
    color: #9195a3;
    font-size: 32rpx;
    font-weight:500;
}
.content-item .arrow-bg{
    width: 35rpx;
    height: 35rpx;
    position: absolute;
    right:30rpx;
}