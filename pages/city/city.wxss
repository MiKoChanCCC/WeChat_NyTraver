/* pages/city.wxss */
page{
    background-color: #efefef;
}
/* 区域展示列表 */
.area{
    height: 90vh;
}
.area-item{
    width: 700rpx;
}
.item-conetnt{
    width: 700rpx;
}
.item-content .title{
    width: 100%;
    height: 60rpx;
    line-height: 60rpx;
    padding-left: 25rpx;
    box-sizing: border-box;
    display: inline-block;
    background-color: #efefef;
}
.item-content .content text{
    width: 100%;
    height: 90rpx;
    line-height: 90rpx;
    padding-left: 25rpx;
    box-sizing: border-box;
    display: inline-block;
    font-size: 32rpx;
    color: #9195a3;
    border-top: 1px solid #efefef;
    background-color: #fff;
}
/* 固定导航 */
.fixedSortNav{
    width: 20px;
    color:#b5b7be;
    position: fixed;
    right: 5rpx;
    top:150rpx;
    z-index: 9;
    font-size: 28rpx;
}
.nav-content{
    display: flex;
    align-items: center;
    flex-direction: column;
}
.nav-content .content-item{
    font-size: 28rpx;
}