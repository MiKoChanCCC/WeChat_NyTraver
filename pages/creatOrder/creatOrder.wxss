page{
    background-color: #efefef;
}
.top{
    width: 710rpx;
    height: 90rpx;
    margin: 20rpx 20rpx;
    border-radius: 20rpx;
    line-height: 90rpx;
    background-color: #fff;
}
.top-orderTime{
    width: 100%;
    height: 100%;
    padding:0 30rpx;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
}
.top-orderTime text{
    font-size: 28rpx;
    color: #aaa4aa;
}
/* 票面信息 */
.ticket{
    width: 710rpx;
    margin: 0 20rpx;
    border-radius: 20rpx;
    background-color: #fff;
}
.ticket-trip{
    width: 100%;
    height: 130px;
}
.trip-city{
    width: 100%;
    height: 80rpx;
    display: flex;
    justify-content: space-around;
    align-items: center;
    font-size: 38rpx;
    font-weight: 800;
}
.trip-time{
    font-size: 26rpx;
}
.trip-bg image{
    width: 200rpx;
    height: 30rpx;
}
.trip-time{
    padding:0 30rpx;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #aaa4aa;
}
.trip-seat{
    padding: 0 30rpx;
    margin: 20rpx 0;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #aaa4aa;
}
.seat-tip{
    background-color: #ffaa43;
    color: #efefef;
}
.trip-orderNum{
    padding: 0 30rpx;
    color: #756666;
}
.ticket-info{
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100rpx;
    color:#fff;
    display: flex;
    justify-content: space-around;
    align-items: center;
    background-color: #919191;
    padding-bottom: constant(safe-area-inset-bottom);
    padding-bottom: env(safe-area-inset-bottom);
}
.submit{
    width: 20%;
    height: 100%;
    line-height: 100rpx;
    text-align: center;
    background: #ff0000;
}